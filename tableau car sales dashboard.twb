      <column caption='YTD total sales' datatype='integer' default-format='c&quot;$&quot;#,##0,,.00M;(&quot;$&quot;#,##0,,.00M)' name='[Calculation_0662512885927936]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF &#13;&#10;YEAR([Date])= {FIXED :MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Price ($)]&#13;&#10;END )' />
      </column>
      <column caption='YOY Sales Growth' datatype='real' default-format='p0.00%' name='[Calculation_0662512891961346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0662512885927936]-[YTD total sales (copy)_0662512891621377]) / [YTD total sales (copy)_0662512891621377]' />
      </column>
      <column caption='YTD Cars Sold' datatype='integer' default-format='c&quot;# &quot;#,##0,.00K;(&quot;# &quot;#,##0,.00K)' name='[Calculation_0662512894734339]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF  &#13;&#10;YEAR([Date])={MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='YOY Car  Sold Growth' datatype='real' name='[Calculation_0662512895381509]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0662512894734339]-[YTD Cars Sold (copy)_0662512895279108])/[YTD Cars Sold (copy)_0662512895279108]' />
      </column>
      <column caption='YTD Avg Price' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;(&quot;$&quot;#,##0,.00K)' name='[Calculation_0662512896917510]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0662512885927936] / [Calculation_0662512894734339]' />
      </column>
      <column caption='PYTD Avg Price' datatype='real' name='[Calculation_0662512897044487]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD total sales (copy)_0662512891621377] / [YTD Cars Sold (copy)_0662512895279108]' />
      </column>
      <column caption='YoY Avg Growth' datatype='real' name='[Calculation_0662512897306632]' role='measure' type='quantitative'>
